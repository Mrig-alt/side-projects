# ============================================================
# Personal Intelligence Feed — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ── Claude (Anthropic) ───────────────────────────────────────
# Used for: article summaries, developing story analysis, top-3 story selection
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Perplexity Pro ───────────────────────────────────────────
# Used for: daily follow-up tracking (web search) + live search briefings
# Perplexity sonar-pro has real-time internet — critical for follow-up feature.
# Get your key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ── OpenAI (IE partnership / ChatGPT) ───────────────────────
# Used for: alternative/cross-validation summaries
# Set SUMMARY_AI=openai to default to GPT-4o, or SUMMARY_AI=both for side-by-side.
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Which AI to use for article summaries: claude | openai | both
SUMMARY_AI=claude

# ── NewsAPI ──────────────────────────────────────────────────
# Used for: on-demand search (any topic from search bar)
# Free tier: 100 req/day  |  Paid: no limits
# Get your key: https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here

# ── Premium News Site Cookies ────────────────────────────────
# HOW TO GET YOUR COOKIES:
#   Option A (easiest): Install "Cookie-Editor" browser extension
#     1. Log into the news site in your browser
#     2. Click Cookie-Editor → Export → "Header String"
#     3. Paste the result in the variable below
#
#   Option B: Browser DevTools
#     1. Log into the site → F12 → Network tab → reload
#     2. Click any request to the site → Headers → copy "cookie:" value
#
# IMPORTANT: Cookie strings expire. Re-export when feeds stop working.

NYT_COOKIES=your_nyt_session_cookie_string_here
# Example format: nyt-a=AbCdEf12345; NYT-S=0H9a8b7c6d5e4f3g2h1; ...

FT_COOKIES=your_ft_session_cookie_string_here
# Example format: FTSession=abc123def456; FTSession_s=xyz789; ...

WSJ_COOKIES=your_wsj_session_cookie_string_here
# Example format: wsjregion=na%2Cus; ar_p=xyz; DJ.pac=abc; ...

ECONOMIST_COOKIES=your_economist_session_cookie_string_here
# Example format: ey_cks=xxx; ey_tkn=xxx; ...

# ── App Settings (optional overrides) ───────────────────────
REFRESH_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_FEED=8
MAX_ARTICLES_AGE_HOURS=48
PORT=8000
# Hour (UTC) to run the daily Perplexity follow-up check (default: 9 AM UTC)
FOLLOWUP_CHECK_HOUR_UTC=9

# ── Database (SQLite) ────────────────────────────────────────
# Path to the SQLite file for persisting custom topics, follow-ups, and alerts.
# Defaults to ./data/feed.db relative to main.py.
#
# For Oracle Cloud: use the mounted persistent volume path, e.g.:
#   DATABASE_PATH=/opt/intel-feed/data/feed.db
#
# For Fly.io: set to the mounted volume path, e.g.:
#   DATABASE_PATH=/app/data/feed.db  (matches fly.toml [mounts] destination)
#
# For local dev: leave unset — uses ./data/feed.db automatically.
DATABASE_PATH=

# ── Web Push / PWA Notifications ────────────────────────────
# Required for push notifications when the browser tab is closed.
# Generate keys ONCE with:
#
#   pip install pywebpush
#   python deploy/generate_vapid.py
#
# Then paste the output here. Never regenerate — changing keys breaks
# all existing push subscriptions (users must re-enable notifications).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# A contact email shown to push services (required by Web Push spec)
VAPID_EMAIL=mailto:you@example.com
