# ── Telegram Bot ──────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 2. Your personal Telegram chat ID
#    Easiest way: message @userinfobot — it replies with your ID
TELEGRAM_CHAT_ID=123456789

# ── Schedule ──────────────────────────────────────────────────────────────────
# Morning poll: "Which tasks are you doing today?"
MORNING_POLL_TIME=08:00

# Evening poll: "Which tasks did you complete?"
EVENING_POLL_TIME=21:00

# Your timezone (e.g. Europe/London, America/New_York, Asia/Kolkata)
TIMEZONE=UTC

# ── Google Calendar (optional) ────────────────────────────────────────────────
# Path to your OAuth credentials JSON downloaded from Google Cloud Console.
# Leave blank to run the bot without calendar sync.
# Setup: python setup_calendar.py
GOOGLE_CREDENTIALS_PATH=credentials.json

# Days before a deadline/birthday to start sending countdown alerts each morning
COUNTDOWN_THRESHOLD_DAYS=10
