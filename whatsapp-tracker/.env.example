# Twilio credentials — get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio WhatsApp sandbox number (default for sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# YOUR WhatsApp number (international format, e.g. +447911123456)
MY_WHATSAPP_NUMBER=whatsapp:+1234567890

# Time to send the daily poll (24h format, local timezone)
POLL_TIME=21:00

# Your timezone (e.g. Europe/London, America/New_York, Asia/Kolkata)
TIMEZONE=UTC

# Port for the webhook server
WEBHOOK_PORT=5000
