# ── Meta WhatsApp Cloud API ────────────────────────────────────────────────────
# Get from: developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_API_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Random string you choose — used to verify the webhook with Meta
WHATSAPP_VERIFY_TOKEN=any_random_secret_string

# YOUR WhatsApp number (international format, no + or spaces, e.g. 447911123456)
MY_WHATSAPP_NUMBER=447911123456

# ── Schedule ──────────────────────────────────────────────────────────────────
# Morning poll: "Which tasks are you doing today?"
MORNING_POLL_TIME=08:00

# Evening poll: "Which tasks did you complete?"
EVENING_POLL_TIME=21:00

# Your timezone (e.g. Europe/London, America/New_York, Asia/Kolkata)
TIMEZONE=UTC

# ── Server ────────────────────────────────────────────────────────────────────
WEBHOOK_PORT=5000

# ── Todoist integration (optional) ────────────────────────────────────────────
# When set, morning polls pull live uncompleted tasks from your Todoist project
# instead of tasks.json. Evening completions are automatically closed in Todoist.
# Get your API token from: todoist.com → Settings → Integrations → Developer
TODOIST_API_TOKEN=

# Which project to pull tasks from (default: Inbox)
TODOIST_PROJECT_NAME=Inbox

# Max tasks to include in the poll (WhatsApp limit is 12)
TODOIST_TASK_LIMIT=10

# Set to false to disable auto-closing completed tasks in Todoist
TODOIST_CLOSE_ON_COMPLETE=true
